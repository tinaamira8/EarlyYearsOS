# Browser-safe Supabase credentials. Keep RLS enabled on exposed tables.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me

# Server-only integration secrets. Never expose these through VITE_* variables.
SUPABASE_SECRET_KEY=sb_secret_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_EDUCATOR=price_replace_me
STRIPE_PRICE_CENTRE=price_replace_me
RESEND_API_KEY=re_replace_me
GEMINI_API_KEY=replace_me
